# ============================================================================
#  ZERO — Environment Variables (server)
#  Copy this file to `server/.env` and adjust values as needed.
# ============================================================================

# --- Server -----------------------------------------------------------------
PORT=3001
JWT_SECRET=change-this-in-production-please

# Hard-coded admin credentials (also auto-created by `npm run seed`)
# NOTE: Always wrap values containing # in quotes — dotenv treats # as a comment.
ADMIN_EMAIL=zeru50549@gmail.com
ADMIN_PASSWORD="zero7892345##"

# --- Database ----------------------------------------------------------------
# Choose ONE of the two options below.

# Option A — SQLite (default, zero-config dev DB)
#   File lives at server/prisma/dev.db
DATABASE_URL="file:./dev.db"

# Option B — PostgreSQL (recommended for production)
#   1. Make sure PostgreSQL is running and you created a database (e.g. `zero_db`).
#   2. Update schema.prisma datasource.provider to "postgresql".
#   3. Uncomment and edit the line below.
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zero_db?schema=public"

# --- Uploads -----------------------------------------------------------------
# Where uploaded media files are stored (relative to server/ root).
UPLOAD_DIR=uploads
# Max upload size in megabytes (per file).
UPLOAD_MAX_MB=10

# --- Frontend (Vite) ---------------------------------------------------------
VITE_API_BASE=/api
